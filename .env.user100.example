# .env.user100.example — copy to .env.user100 and fill in real values
# Usage: docker compose -f docker-compose.user100.yml --env-file .env.user100 up

# ── Z.AI / GLM-4.7 (openclaw agent model) ───────────────────────────────────
# API key from https://open.bigmodel.cn (Zhipu AI / Z.AI)
ZAI_API_KEY=your-zai-key.suffix
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZAI_MODEL=glm-4-flash

# ── OpenAI key scoped to mem0 only ───────────────────────────────────────────
# mem0 uses OpenAI for embeddings + LLM. Use a separate key here so it
# does not conflict with the Z.AI key above.
MEM0_OPENAI_API_KEY=sk-proj-...

# ── Anthropic (optional fallback for openclaw) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── mem0 managed platform (leave empty = self-hosted local store) ────────────
MEM0_API_KEY=
